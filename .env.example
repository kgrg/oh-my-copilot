# Copy to `.env` (gitignored) and fill in. Source it before `omp slack serve`:
#   set -a; . ./.env; set +a            # bash/zsh
# Never commit real tokens. If a token leaks, rotate it in your Slack app admin.

# Slack app tokens (from your Slack app — see docs/slack-setup.md)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token   # Socket Mode, scope connections:write

# Optional policy
# SLACK_ALLOWED_USERS=U0123456789,U0987654321   # CSV of user IDs; omit or "*" = everyone
# SLACK_REQUIRE_MENTION=true                      # require @mention in channels (default true)

# Optional: pin the Copilot tmux session (otherwise auto-discovered)
# COPILOT_TMUX_SESSION=omp-1700000000000
